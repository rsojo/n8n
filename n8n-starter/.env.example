# Copia este archivo a `.env` y completa valores reales fuera del repo

# Core UI
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678
N8N_EDITOR_BASE_URL=http://localhost:5678
N8N_CORS_ALLOW_ORIGIN=http://localhost:5678
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=change-me
N8N_BASIC_AUTH_PASSWORD=change-me
GENERIC_TIMEZONE=America/Bogota

# Runtime
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
DB_SQLITE_POOL_SIZE=5
N8N_RUNNERS_ENABLED=true
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# Integración con API staging
API_BASE_URL=https://api-staging.example.com
N8N_API_KEY=replace-me

# Gmail / Google
GMAIL_CREDENTIAL_NAME=Gmail OAuth2 API
GOOGLE_DRIVE_CREDENTIAL_NAME=Google Drive OAuth2 API

# Workflow import
WORKFLOW_NAME=Gmail to Backend Invoice Intake
